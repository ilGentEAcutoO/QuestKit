{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Test-only wrangler config — mirrors wrangler.jsonc. The `ai` binding IS
  // declared here so route tests can patch `env.AI.run` via `vi.spyOn` and
  // hit the real route surface (TASK-017). Workers AI has no local emulator;
  // pool-workers 0.16 opens a remote-proxy session lazily — that only fails
  // if a test actually invokes `env.AI.run` without first mocking it. Every
  // AI-touching test under `test/` MUST mock the binding before exercising
  // the route. See `test/recommendations.route.test.ts` for the pattern.
  //
  // Service-layer ai.ts tests bypass `env.AI` entirely (they construct a
  // hand-rolled env). Only route tests use the real binding shape with a
  // patched .run method.
  "name": "questkit-worker-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-19",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "questkit-d1-main",
      "database_id": "<set-per-env>"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "<set-per-env>"
    }
  ],

  "r2_buckets": [
    {
      "binding": "ASSETS_R2",
      "bucket_name": "questkit-r2-assets"
    }
  ],

  "queues": {
    "producers": [
      {
        "binding": "WEBHOOK_QUEUE",
        "queue": "questkit-queue-webhooks"
      }
    ]
  },

  "durable_objects": {
    "bindings": [
      { "name": "RATE_LIMITER", "class_name": "RateLimiter" },
      { "name": "SSE_HUB", "class_name": "SSEHub" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RateLimiter", "SSEHub"]
    }
  ],

  "analytics_engine_datasets": [
    {
      "binding": "EVENTS_AE",
      "dataset": "questkit_events"
    }
  ],

  // Workers AI — declared so route tests can patch `env.AI.run` via
  // `vi.spyOn`. Tests MUST mock `.run` before invoking the route — without
  // a mock the call would hit Cloudflare's real inference API (and CI has
  // no credentials, so it would fail). Pool-workers prints a one-per-file
  // "may incur usage charges" warning at start-up; that's harmless because
  // every AI-touching test mocks before invoking. `remote: true` is
  // intentionally omitted — adding it makes pool-workers try to open a
  // remote-proxy session at start-up which fails in CI without
  // CLOUDFLARE_API_TOKEN.
  "ai": { "binding": "AI" }
}
