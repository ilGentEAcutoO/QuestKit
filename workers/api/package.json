{
  "name": "@questkit/worker-api",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "questkit-worker-api — REST + SSE + Durable Objects + Workers AI + D1 + KV + R2 + Analytics Engine.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "db:migrate:local": "wrangler d1 migrations apply questkit-d1-main --local",
    "db:migrate:remote": "wrangler d1 migrations apply questkit-d1-main --remote --config wrangler.dev.jsonc",
    "db:seed:local": "wrangler d1 execute questkit-d1-main --file=./migrations/0002_seed_sample_data.sql --local",
    "db:seed:remote": "wrangler d1 execute questkit-d1-main --file=./migrations/0002_seed_sample_data.sql --remote --config wrangler.dev.jsonc"
  },
  "dependencies": {
    "@questkit/types": "workspace:^",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "^4.1.6",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
