{
  "name": "@questkit/core",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "QuestKit client SDK — auth, events, missions, balance, campaigns, SSE.",
  "license": "MIT",
  "homepage": "https://github.com/ilGentEAcutoO/QuestKit/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilGentEAcutoO/QuestKit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ilGentEAcutoO/QuestKit/issues"
  },
  "keywords": [
    "questkit",
    "gamification",
    "sdk",
    "cloudflare"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@questkit/types": "workspace:^"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "rimraf": "^6.0.1",
    "ts-jest": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unrun": "^0.3.0"
  }
}
