{
  "name": "@questkit/types",
  "type": "module",
  "version": "0.1.0",
  "description": "Shared TypeScript types for QuestKit — the type contract every other package depends on.",
  "license": "MIT",
  "homepage": "https://github.com/ilGentEAcutoO/QuestKit/tree/main/packages/types#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilGentEAcutoO/QuestKit.git",
    "directory": "packages/types"
  },
  "bugs": {
    "url": "https://github.com/ilGentEAcutoO/QuestKit/issues"
  },
  "keywords": [
    "questkit",
    "gamification",
    "types"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
